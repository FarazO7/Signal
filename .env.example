# Copy this file to .env and fill in your key. .env is gitignored — never commit it.
# The key is read ONLY server-side (API routes / eval runner). It is never shipped
# to the browser.

# Your OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Model routing (README Decision 3). Cheap model for simple classification,
# capable model for synthesis and low-confidence cases. Override to swap models.
SIGNAL_MODEL_CHEAP=gpt-4o-mini
SIGNAL_MODEL_SMART=gpt-4o
